{
  "name": "@byteroute/dashboard",
  "private": true,
  "type": "module",
  "version": "5.12.0",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "license:add:src": "cd src && license-check-and-add add -f ../../../.license-check-and-add.json",
    "license:check:src": "cd src && license-check-and-add check -f ../../../.license-check-and-add.json",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser-chromium --project browser-firefox --project browser-webkit --project browser-mobile --browser.headless",
    "test:browser:watch": "vitest --project browser-chromium --project browser-firefox --project browser-webkit --project browser-mobile",
    "coverage": "vitest run --project unit --coverage",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@byteroute/shared": "workspace:^5.3.0",
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/layers": "^9.3.4",
    "@deck.gl/mapbox": "^9.3.4",
    "@primevue/themes": "^4.5.4",
    "@tanstack/vue-query": "^5.101.1",
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "maplibre-gl": "5.24.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "3.0.4"
  },
  "devDependencies": {
    "@byteroute/typescript": "workspace:^5.3.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "sass": "^1.101.0",
    "typescript": "6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "^3.0.4",
    "vue-tsc": "^3.3.5"
  }
}
