{
  "name": "@byteroute/dashboard",
  "private": true,
  "type": "module",
  "version": "5.5.1",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser-chromium --project browser-firefox --project browser-webkit --project browser-mobile --browser.headless",
    "test:browser:watch": "vitest --project browser-chromium --project browser-firefox --project browser-webkit --project browser-mobile",
    "coverage": "vitest run --project unit --coverage",
    "test:watch": "vitest --project unit"
  },
  "dependencies": {
    "@byteroute/shared": "workspace:^5.3.0",
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@primevue/themes": "^4.5.4",
    "@tanstack/vue-query": "^5.92.9",
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "maplibre-gl": "5.20.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-virtual-scroller": "2.0.0-beta.10"
  },
  "devDependencies": {
    "@byteroute/typescript": "workspace:^5.3.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "playwright": "^1.58.2",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.29",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.3",
    "vue-virtual-scroller": "^2.0.0-beta.10",
    "vue-tsc": "^3.2.5"
  }
}
