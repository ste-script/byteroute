{
  "name": "@byteroute/backend",
  "private": true,
  "version": "5.11.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "pnpm typecheck && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint --fix --config eslint.config.ts",
    "pretest": "pnpm -C ../../packages/shared build",
    "test": "pnpm test:unit && pnpm test:e2e",
    "pretest:unit": "pnpm -C ../../packages/shared build",
    "test:unit": "vitest run",
    "update:maxmind": "node scripts/download-maxmind.mjs",
    "test:watch": "vitest --watch",
    "coverage:unit": "vitest run --coverage",
    "coverage:e2e": "node scripts/coverage-e2e.mjs",
    "coverage:merge": "node scripts/merge-coverage.mjs",
    "coverage": "pnpm coverage:unit && pnpm coverage:e2e && pnpm coverage:merge",
    "migrate:indexes": "tsx scripts/ensure-connection-indexes.mjs",
    "pretest:e2e": "pnpm -C ../../packages/shared build",
    "test:e2e": "NODE_OPTIONS='--import tsx' cucumber-js 'test/features/**/*.feature' --import 'test/features/support/**/*.ts' --import 'test/features/step_definitions/**/*.ts'",
    "docs:api": "typedoc --entryPointStrategy expand --entryPoints src --out docs/api --tsconfig tsconfig.build.json"
  },
  "devDependencies": {
    "@byteroute/typescript": "workspace:^5.3.0",
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/ip": "^1.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/passport": "^1.0.17",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "monocart-coverage-reports": "^2.12.9",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "typedoc": "^0.28.17",
    "vitest-monocart-coverage": "^4.0.1"
  },
  "dependencies": {
    "@byteroute/shared": "workspace:^5.3.0",
    "@maxmind/geoip2-node": "^6.3.4",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
